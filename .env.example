# Copy to .env and adjust. SECRET_KEY_BASE is required; everything else has a
# working local default you only need to change when exposing Messy on a real
# domain.

# Postgres password for the bundled db service (also embedded in DATABASE_URL).
POSTGRES_PASSWORD=messy

# Public URLs. API_URL is what browsers use to reach the Rails API; FRONTEND_URL
# is the app's own address (also the allowed CORS origin).
API_URL=http://localhost:8081
FRONTEND_URL=http://localhost:8080

# Session/JWT signing secret. Required. Generate: openssl rand -hex 64
SECRET_KEY_BASE=

# From-address for system mail: magic-link logins and signup verification.
EMAIL_FROM=messy@localhost

# System mail needs one of the two below. Simplest: any SMTP relay.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Alternative to SMTP: AWS SES credentials (SES delivery is used when
# SMTP_ADDRESS is unset).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
