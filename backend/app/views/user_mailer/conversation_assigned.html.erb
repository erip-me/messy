<p style="margin: 0 0 8px; font-size: 15px; color: #334155; line-height: 1.6;">
  Hi<%= @user.operator_profile&.public_name.present? ? " #{@user.operator_profile.public_name}" : (@user.name.present? ? " #{@user.name}" : "") %>,
</p>

<p style="margin: 0 0 24px; font-size: 15px; color: #64748b; line-height: 1.6;">
  A conversation has been assigned to you<%= @assigned_by && @assigned_by.id != @user.id ? " by #{@assigned_by.name}" : "" %>.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px; width: 100%; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
  <tr>
    <td style="padding: 16px 20px;">
      <p style="margin: 0 0 6px; font-size: 14px; color: #334155; font-weight: 600;">
        <%= @conversation.visitor_name || "Visitor" %>
      </p>
      <% if @conversation.visitor_email.present? %>
        <p style="margin: 0 0 6px; font-size: 13px; color: #64748b;">
          <%= @conversation.visitor_email %>
        </p>
      <% end %>
      <% if @conversation.last_message_preview.present? %>
        <p style="margin: 0; font-size: 13px; color: #94a3b8; font-style: italic;">
          &ldquo;<%= truncate(@conversation.last_message_preview, length: 120) %>&rdquo;
        </p>
      <% end %>
    </td>
  </tr>
</table>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 28px;">
  <tr>
    <td style="border-radius: 9999px; background: #3b82f6;">
      <a href="<%= @inbox_link %>" style="display: inline-block; padding: 12px 28px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; font-weight: 600; color: #ffffff; text-decoration: none; border-radius: 9999px;">
        Open conversation
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0; font-size: 13px; color: #94a3b8; line-height: 1.5;">
  You can reply directly from your Messy inbox.
</p>
