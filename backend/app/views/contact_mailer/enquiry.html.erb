<%
  rows = [
    ["Name",           @contact[:name]],
    ["Email",          @contact[:email]],
    ["Company",        @contact[:company]],
    ["Role",           @contact[:role]],
    ["Company size",   @contact[:company_size]],
    ["Using today",    @contact[:current_stack]],
    ["Monthly volume", @contact[:monthly_volume]],
    ["Channels",       @contact[:channels].to_a.join(", ")],
    ["Looking for",    @contact[:interest]],
    ["Timeline",       @contact[:timeline]]
  ].reject { |_, v| v.blank? }
%>

<p style="margin: 0 0 24px; font-size: 15px; color: #64748b; line-height: 1.6;">
  <%= @contact[:enterprise] ? "An enterprise enquiry" : "A message" %> came in from the website.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px; width: 100%; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
  <% rows.each_with_index do |(label, value), i| %>
    <tr>
      <td style="padding: 12px 20px; width: 1%; white-space: nowrap; font-size: 13px; color: #94a3b8; vertical-align: top; <%= "border-top: 1px solid #e2e8f0;" if i.positive? %>">
        <%= label %>
      </td>
      <td style="padding: 12px 20px; font-size: 14px; color: #334155; <%= "border-top: 1px solid #e2e8f0;" if i.positive? %>">
        <%= value %>
      </td>
    </tr>
  <% end %>
</table>

<% if @contact[:goals].present? %>
  <p style="margin: 0 0 6px; font-size: 13px; color: #94a3b8;">What they want to achieve</p>
  <p style="margin: 0 0 24px; font-size: 14px; color: #334155; line-height: 1.7; white-space: pre-wrap;"><%= @contact[:goals] %></p>
<% end %>

<% if @contact[:message].present? %>
  <p style="margin: 0 0 6px; font-size: 13px; color: #94a3b8;">Message</p>
  <p style="margin: 0 0 28px; font-size: 14px; color: #334155; line-height: 1.7; white-space: pre-wrap;"><%= @contact[:message] %></p>
<% end %>

<a href="mailto:<%= @contact[:email] %>" style="display: inline-block; background: #3b82f6; color: #ffffff; text-decoration: none; padding: 12px 28px; border-radius: 9999px; font-size: 15px; font-weight: 600;">
  Reply to <%= @contact[:name] %>
</a>
