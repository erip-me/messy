<p style="margin: 0 0 16px; font-size: 15px; color: #334155; line-height: 1.6;">
  A new <%= @source_label.downcase %> ticket has been created.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px; width: 100%; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden;">
  <tr>
    <td style="padding: 16px 20px;">
      <p style="margin: 0 0 8px; font-size: 13px; color: #64748b;">
        <strong>From:</strong> <%= @requester_name %><% if @requester_email.present? %> (<%= @requester_email %>)<% end %>
      </p>
      <p style="margin: 0 0 8px; font-size: 13px; color: #64748b;">
        <strong>Subject:</strong> <%= @subject %>
      </p>
      <% if @preview.present? %>
        <p style="margin: 0; font-size: 13px; color: #64748b; font-style: italic;">
          &ldquo;<%= @preview %>&rdquo;
        </p>
      <% end %>
    </td>
  </tr>
</table>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 28px;">
  <tr>
    <td style="border-radius: 9999px; background: #3b82f6;">
      <a href="<%= @inbox_link %>" style="display: inline-block; padding: 12px 28px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; font-weight: 600; color: #ffffff; text-decoration: none; border-radius: 9999px;">
        Open ticket
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0; font-size: 13px; color: #94a3b8; line-height: 1.5;">
  Ticket: <strong><%= @ticket_number %></strong> &middot; Source: <%= @source_label %>
</p>
