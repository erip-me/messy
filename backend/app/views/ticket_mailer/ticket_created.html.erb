<% if @auto_reply_html %>
  <%= @auto_reply_html %>
<% else %>
  <p style="margin: 0 0 16px; font-size: 15px; color: #334155; line-height: 1.6;">
    Thank you for contacting us. We've received your request and assigned it ticket number
    <strong><%= @ticket_number %></strong>.
  </p>
  <p style="margin: 0 0 24px; font-size: 15px; color: #64748b; line-height: 1.6;">
    We'll get back to you as soon as possible. Please include the ticket number in any follow-up correspondence.
  </p>
<% end %>

<p style="margin: 0; font-size: 13px; color: #94a3b8; line-height: 1.5;">
  Ticket: <strong><%= @ticket_number %></strong> &middot; <%= @subject %>
</p>
